{
  "name": "alignkit",
  "version": "0.1.6",
  "description": "Instruction intelligence for coding agents",
  "type": "module",
  "bin": {
    "alignkit": "./dist/cli/index.js",
    "alignkit-mcp": "./bin/mcp-server.mjs"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai",
    "agent",
    "claude",
    "claude-code",
    "cursor",
    "mcp",
    "instruction",
    "rules",
    "lint",
    "agents-md",
    "developer-tools"
  ],
  "license": "MIT",
  "homepage": "https://github.com/mbwsims/alignkit#readme",
  "bugs": {
    "url": "https://github.com/mbwsims/alignkit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mbwsims/alignkit"
  },
  "files": [
    "dist",
    "bin"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "commander": "^14.0.3",
    "globby": "^16.2.0",
    "js-tiktoken": "^1.0.21",
    "jsonc-parser": "^3.3.1",
    "ora": "^8.2.0",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
